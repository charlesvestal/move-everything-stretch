{
  "title": "Time Stretch",
  "children": [
    {
      "title": "Overview",
      "lines": [
        "Change the tempo of a",
        "WAV file without",
        "altering its pitch.",
        "",
        "Uses the Bungee",
        "library for high",
        "quality stretching.",
        "",
        "Set the file's bar",
        "length and target BPM",
        "to hear the result",
        "in real time."
      ]
    },
    {
      "title": "Controls",
      "lines": [
        "Jog: navigate menu",
        "Jog click: edit value",
        "Pads: toggle playback",
        "Back: exit tool",
        "",
        "Menu items:",
        " Bars: song length",
        "   (1/4 to 16 bars)",
        " Target BPM: desired",
        "   tempo (40-300)",
        " Save: export result"
      ]
    },
    {
      "title": "Saving",
      "lines": [
        "Two save modes:",
        "",
        "Overwrite: replaces",
        " the original file",
        "",
        "New File: browse to",
        " a destination folder",
        " and save with BPM",
        " in the filename",
        " (e.g. loop-120bpm)"
      ]
    },
    {
      "title": "Tips",
      "lines": [
        "Set Bars first, then",
        "adjust Target BPM.",
        "",
        "Source BPM is shown",
        "at the top alongside",
        "the speed multiplier.",
        "",
        "Press any pad to",
        "preview the stretched",
        "audio in real time",
        "before saving."
      ]
    }
  ]
}
